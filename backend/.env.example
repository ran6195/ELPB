# ===== DATABASE CONFIGURATION =====
# Configura con le credenziali del database
DB_DRIVER=mysql
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=landing_page_builder
DB_USERNAME=root
DB_PASSWORD=

# ===== APPLICATION CONFIGURATION =====
APP_ENV=development
APP_DEBUG=true

# ===== APPLICATION URL =====
# IMPORTANTE: Imposta l'URL pubblico dell'applicazione
# Usato per generare URL assoluti per immagini e asset
# Development: http://localhost:8000
# Production: https://edysma.net/ELPB/backend/public
APP_URL=http://localhost:8000

# ===== BASE PATH =====
# Imposta solo se l'app è in una sottocartella
# Development: lascia vuoto
# Production in sottocartella: /ELPB/backend/public
BASE_PATH=

# ===== JWT CONFIGURATION =====
# IMPORTANTE: Genera una chiave sicura per la produzione!
# Comando: openssl rand -base64 64
JWT_SECRET=your-super-secret-jwt-key-change-in-production
