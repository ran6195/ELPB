# API Configuration
API_BASE_URL=https://edysma.net/ELPB/backend/public/api

# Optional: Set custom page slug via URL parameter
# Usage: page.php?slug=your-page-slug
# If not provided, will try to get from PATH_INFO or default slug

# Optional: Default slug if none provided
# DEFAULT_SLUG=homepage

# Debug mode (set to true to see error messages)
DEBUG=false

# Cache settings (optional)
ENABLE_CACHE=false
CACHE_TTL=3600
