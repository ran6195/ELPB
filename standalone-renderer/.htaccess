# Landing Page Standalone Renderer - Apache Configuration

# Abilita URL Rewriting
<IfModule mod_rewrite.c>
    RewriteEngine On

    # ⚠️ IMPORTANTE: Modifica RewriteBase in base alla tua directory
    #
    # Se i file sono nella root del dominio:
    # RewriteBase /
    #
    # Se i file sono in una sottodirectory, usa il path completo:
    # Esempio per https://tuodominio.com/testLPSA/
    # RewriteBase /testLPSA/
    #
    # Esempio per https://tuodominio.com/landing/
    # RewriteBase /landing/

    RewriteBase /

    # Se il file o directory esiste, servilo direttamente
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d

    # Altrimenti reindirizza a page.php passando lo slug come query string
    # Nota: Usa query string invece di PATH_INFO per compatibilità con PHP-FPM
    # Se ottieni "No input file specified", questa è la configurazione corretta
    RewriteRule ^(.+)$ page.php?slug=$1 [L,QSA]
</IfModule>

# Proteggi il file .env
<Files .env>
    Order allow,deny
    Deny from all
</Files>

# Proteggi altri file sensibili
<FilesMatch "^(config\.php|BlockRenderer\.php|README\.md)$">
    Order allow,deny
    Deny from all
</FilesMatch>

# Abilita compressione GZIP
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css application/javascript
</IfModule>

# Cache per risorse statiche (se presenti)
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType image/jpg "access plus 1 month"
    ExpiresByType image/jpeg "access plus 1 month"
    ExpiresByType image/gif "access plus 1 month"
    ExpiresByType image/png "access plus 1 month"
    ExpiresByType text/css "access plus 1 week"
    ExpiresByType application/javascript "access plus 1 week"
</IfModule>

# Sicurezza: Disabilita directory listing
Options -Indexes

# Sicurezza: Previeni accesso ai file di backup
<FilesMatch "\.(bak|config|sql|fla|psd|ini|log|sh|inc|swp|dist)$">
    Order allow,deny
    Deny from all
</FilesMatch>
